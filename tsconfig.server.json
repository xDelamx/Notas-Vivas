{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist-server",
    "allowSyntheticDefaultImports": true
  },
  "include": ["server.ts", "src/types.ts", "src/types/express.d.ts"]
}
